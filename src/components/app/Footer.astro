---
import config from "@util/themeConfig";
import { Icon } from "astro-icon/components";

const github = config.footer.socials.github?.link;
---

<footer
  class="border-t border-gray-200 dark:border-gray-600 mt-24"
  aria-labelledby="footer-heading"
>
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 py-10 lg:px-8">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        &copy; {new Date().getFullYear()} <strong>{config.general.title}</strong>
        &middot; {config.footer.description}
      </p>
      {
        github && (
          <a
            href={github}
            class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200"
          >
            <Icon name="tabler:brand-github" class="h-5 w-5" />
            <span>GitHub</span>
          </a>
        )
      }
    </div>
  </div>
</footer>
